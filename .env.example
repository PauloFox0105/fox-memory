# FoxMemory Configuration
# Copy to .env and fill in your values

# API key for REST API authentication (required)
# Generate: python3 -c "import secrets; print('foxmem_' + secrets.token_hex(32))"
FOXMEMORY_API_KEY=

# E2E decryption key for server-side decrypt (optional, base64-encoded 256-bit)
# Generate: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
FOXMEMORY_DECRYPT_KEY=

# MCP Server settings (for Claude.ai integration)
# Public URL of the MCP server (used for OAuth issuer)
MCP_PUBLIC_URL=https://your-domain.com
# Port for MCP server
MCP_PORT=18821
