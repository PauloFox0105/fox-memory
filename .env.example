# FoxMemory Configuration
# Copy to .env and fill in your values

# API key for authentication (required)
# Generate: python3 -c "import secrets; print('foxmem_' + secrets.token_hex(32))"
FOXMEMORY_API_KEY=

# E2E decryption key (base64-encoded 256-bit key, optional)
# Only needed if clients send E2E encrypted data and you want the API to decrypt
# Generate: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
FOXMEMORY_DECRYPT_KEY=
